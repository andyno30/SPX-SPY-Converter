# Required for reading news table from Next.js
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required only if you enable the Vercel cron bridge route (/api/cron/fetch-news)
SUPABASE_FETCH_NEWS_URL=https://YOUR_PROJECT_ID.supabase.co/functions/v1/fetch-news
CRON_SECRET=your-vercel-cron-secret
FETCH_NEWS_SECRET=match-the-edge-function-secret
